# Copy to .env and fill in. `.env` is gitignored; this template is committed.
# Only the keys the code actually reads are listed here.

# ─── Database ───
# Local dev — matches infra/docker-compose.dev.yml (host port 5433).
# Read by lib/prisma.ts (runtime) and prisma.config.ts (migrations).
DATABASE_URL="postgresql://coffee:coffee_dev_password@localhost:5433/my_coffee_db?schema=public"

# Prod (Supabase) only — migrations run through this. Put in .env.supabase / Vercel,
# not here. Local docker leaves it empty → prisma.config falls back to DATABASE_URL.
DIRECT_URL=""

# ─── Auth ───
# REQUIRED. JWT signing key (lib/auth/session.ts reads JWT_SECRET).
# Generate: openssl rand -base64 32
JWT_SECRET=""

# ─── File storage ───
# "local" → public/uploads (dev)   ·   "supabase" → Supabase Storage (prod)
STORAGE_DRIVER="local"

# ─── Supabase Storage (only when STORAGE_DRIVER=supabase) ───
# service_role key is server-only — never expose to the client.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_BUCKET="product-images"
